{
  "$schema": "https://opencode.ai/config.json",

  // Change per-role model ids in shared/models.yaml and regenerate agents.
  // This top-level model is the fallback for sessions that do not pick an agent model.
  "default_agent": "orchestrator",
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.4-mini-fast",
  "instructions": [
    "__FORGE_OPENCODE_AGENTS_MD__"
  ],
  "plugin": [
    "./plugins/forge-guard.js"
  ],
  "provider": {
    "openai": {
      "options": {
        "apiKey": "{env:OPENAI_API_KEY}"
      }
    },
    "anthropic": {
      "options": {
        "apiKey": "{env:ANTHROPIC_API_KEY}"
      }
    },
    "ollama": {
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  }
}
